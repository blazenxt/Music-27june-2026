# Required
API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here
SESSION_STRING=your_pyrogram_session_string_here

# Spotify (REQUIRED for /radio + Spotify links)
# Get from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# YouTube cookies — fixes "Sign in to confirm you're not a bot"
# See cookies/HOW_TO_GET_COOKIES.md for instructions
YT_COOKIES_FILE=cookies/youtube.txt

# Optional log channel
LOG_CHANNEL_ID=0
