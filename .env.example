# Required Telegram values
API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=123456789:your_bot_token_here
SESSION_STRING=your_pyrogram_session_string_here

# Optional YouTube cookies. On Railway, upload/copy cookies to this path only if needed.
YT_COOKIES_FILE=cookies/youtube.txt

# Optional
LOG_CHANNEL_ID=0
AUTO_RESUME=true
ADMIN_ONLY_CMDS=true
RADIO_PREFER_SPOTIFY=true
