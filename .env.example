# Required
API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here
SESSION_STRING=your_pyrogram_session_string_here

# NO SPOTIFY CREDENTIALS NEEDED ANYMORE!
# spotdl handles Spotify internally without any API key or Premium

# YouTube cookies — fixes "Sign in to confirm you're not a bot"
# See cookies/HOW_TO_GET_COOKIES.md
YT_COOKIES_FILE=cookies/youtube.txt

# Optional log channel
LOG_CHANNEL_ID=0
